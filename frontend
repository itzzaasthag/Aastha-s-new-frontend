            <div style={{ position: "relative" }}>
              <div style={{ position: "absolute", left: 13, top: "50%", transform: "translateY(-50%)", opacity: .5 }}>
                <Icon name="lock" size={16} color="#2d9e6b"/>
              </div>
              <input className="input-field" value={pass} onChange={e => setPass(e.target.value)}
