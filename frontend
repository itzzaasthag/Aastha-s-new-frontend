              <button key={p.label} onClick={() => { setWaterGoal(p.ml); setGoalInput(String(p.ml)); }}
                style={{ flex:1, padding:"8px 4px", borderRadius:11, border:`1.5px solid ${waterGoal===p.ml?"#2d9e6b":"#e0ece4"}`, background:waterGoal===p.ml?"#e4f5ec":"#fff", cursor:"pointer", textAlign:"center" }}>
