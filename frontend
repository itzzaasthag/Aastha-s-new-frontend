                <p style={{ fontSize:9, color:waterGoal===p.ml?"#2d9e6b":"#7a9e8a" }}>{(p.ml/1000).toFixed(1)}L</p>
                <p style={{ fontSize:8, color:"#7a9e8a" }}>{p.desc}</p>
              </button>
            ))}
          </div>
        </div>

        {/* ── Today's Log ── */}
        {drinkLog.length > 0 && (
          <div style={{ borderTop:"1px solid #f0f5f2", paddingTop:12 }}>
            <div style={{ display:"flex", justifyContent:"space-between", alignItems:"center", marginBottom:8 }}>
