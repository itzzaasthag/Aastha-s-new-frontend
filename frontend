// AUTH: REGISTER
// ════════════════════════════════════════════════════════════════════
function Register({ goHome, goLogin }) {
  const [name,  setName]  = useState("");
  const [email, setEmail] = useState("");
  const [phone, setPhone] = useState("");
  const [pass,  setPass]  = useState("");
  const [err,   setErr]   = useState("");
  const [busy,  setBusy]  = useState(false);

  function submit() {
    setErr("");
    if (!name.trim())  { setErr("Please enter your full name."); return; }
    if (!email.trim()) { setErr("Please enter your email."); return; }
    if (!pass.trim())  { setErr("Please enter a password."); return; }
    setBusy(true);
    // Directly enter app — NO redirect back to login
    setTimeout(() => {
      setBusy(false);
      goHome({ name: name.trim(), email: email.trim() });
    }, 1000);
  }

  const fields = [
    { label: "FULL NAME",    val: name,  set: setName,  ph: "Arjun Sharma",    icon: "user",  type: "text" },
    { label: "EMAIL",        val: email, set: setEmail, ph: "you@example.com", icon: "mail",  type: "email" },
    { label: "PHONE NUMBER", val: phone, set: setPhone, ph: "+91 98765 43210", icon: "phone", type: "tel" },
    { label: "PASSWORD",     val: pass,  set: setPass,  ph: "Create password", icon: "lock",  type: "password" },
  ];

  return (
    <div style={{ minHeight: "100vh", background: "#f4f7f5" }}>
      <div style={{ background: "linear-gradient(155deg,#1565c0,#2d9e6b)", padding: "50px 20px 50px", borderRadius: "0 0 36px 36px", textAlign: "center" }}>
        <div style={{ fontFamily: "Fraunces, serif", fontSize: 24, fontWeight: 700, color: "#fff" }}>Create Account ✨</div>
        <div style={{ fontSize: 13, color: "rgba(255,255,255,.8)", marginTop: 4 }}>Join SwasthayaLink today</div>
      </div>

      <div className="slide-up" style={{ padding: "0 20px 40px", marginTop: -24 }}>
        <div className="card" style={{ padding: 24 }}>
          <div style={{ fontFamily: "Fraunces, serif", fontSize: 20, fontWeight: 700, marginBottom: 4 }}>New Account</div>
          <div style={{ fontSize: 13, color: "#7a9e8a", marginBottom: 20 }}>Fill in your details below</div>

          {err && (
            <div style={{ background: "#fde8e8", borderRadius: 12, padding: "10px 14px", fontSize: 13, color: "#c62828", fontWeight: 600, marginBottom: 14 }}>
              ⚠️ {err}
            </div>
          )}

          {fields.map(f => (
            <div key={f.label} style={{ marginBottom: 12 }}>
              <div style={{ fontSize: 11, fontWeight: 700, color: "#7a9e8a", letterSpacing: ".06em", marginBottom: 6 }}>{f.label}</div>
              <div style={{ position: "relative" }}>
                <div style={{ position: "absolute", left: 13, top: "50%", transform: "translateY(-50%)", opacity: .5 }}>
                  <Icon name={f.icon} size={16} color="#2d9e6b"/>
                </div>
                <input className="input-field" value={f.val} onChange={e => f.set(e.target.value)}
                  onKeyDown={e => e.key === "Enter" && submit()}
                  type={f.type} placeholder={f.ph}
                  style={{ paddingLeft: 40 }}/>
              </div>
            </div>
          ))}

          <button className="btn-primary" onClick={submit} disabled={busy}
            style={{ width: "100%", marginTop: 8, display: "flex", alignItems: "center", justifyContent: "center", gap: 8, background: "linear-gradient(135deg,#1565c0,#2d9e6b)" }}>
            {busy
              ? <><div style={{ width: 18, height: 18, border: "2px solid rgba(255,255,255,.4)", borderTopColor: "#fff", borderRadius: "50%", animation: "spin .7s linear infinite" }}/> Creating account…</>
              : "Create Account →"}
          </button>

          <div style={{ textAlign: "center", fontSize: 13, color: "#7a9e8a", marginTop: 16 }}>
            Already have an account?{" "}
            <button onClick={goLogin} style={{ background: "none", border: "none", cursor: "pointer", color: "#2d9e6b", fontWeight: 700, fontSize: 13 }}>
              Sign In
            </button>
          </div>
        </div>
      </div>
    </div>
  );
}

