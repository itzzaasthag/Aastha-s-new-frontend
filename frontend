              <button key={d.label} onClick={() => { setWater(w=>w+d.ml); const t=new Date(); const ts=t.getHours().toString().padStart(2,"0")+":"+t.getMinutes().toString().padStart(2,"0"); setDrinkLog(l=>[{time:ts,label:`${d.label} ${d.icon}`,amount:d.ml},...l].slice(0,20)); }}
                style={{ flexShrink:0, display:"flex", flexDirection:"column", alignItems:"center", gap:3, padding:"8px 10px", borderRadius:12, border:"1.5px solid #e0ece4", background:"#fff", cursor:"pointer", minWidth:62 }}>
                <span style={{ fontSize:20 }}>{d.icon}</span>
                <span style={{ fontSize:9, fontWeight:700, color:"#1a2e24" }}>{d.label}</span>
                <span style={{ fontSize:9, color:"#7a9e8a" }}>{d.ml}ml</span>
