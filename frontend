// DASHBOARD SHELL
// ════════════════════════════════════════════════════════════════════
function Dashboard({ user, onLogout }) {
  const [tab,      setTab]     = useState("home");
  const [subView,  setSubView] = useState(null);
  const [sosFlash, setSosFlash]= useState(false);

  const handleSOS = () => {
    setSosFlash(true);
    setTimeout(() => setSosFlash(false), 2000);
    setTab("emergency");
    setSubView(null);
  };

  const navItems = [
    { id: "home",      label: "Home",      icon: "home" },
    { id: "health",    label: "Health",    icon: "heart" },
    { id: "myinfo",    label: "My Info",   icon: "shield" },
    { id: "emergency", label: "Emergency", icon: "emergency" },
    { id: "profile",   label: "Profile",   icon: "user" },
  ];

  const renderSubView = () => {
    if (subView === "cpr")      return <CPRGuide       onBack={() => setSubView(null)}/>;
    if (subView === "firstaid") return <FirstAidGuide  onBack={() => setSubView(null)}/>;
    if (subView === "map")      return <MapView         onBack={() => setSubView(null)}/>;
    if (subView === "store")    return <StoreView       onBack={() => setSubView(null)}/>;
    if (subView === "chatbot")  return <ChatbotView     onBack={() => setSubView(null)}/>;
    if (subView === "symptom")  return <SymptomChecker  onBack={() => setSubView(null)}/>;
    if (subView === "stepcounter") return <StepCounter onBack={() => setSubView(null)}/>;
    return null;
  };

  const renderTab = () => {
    if (tab === "home")      return <HomeTab      user={user} setSubView={setSubView}/>;
    if (tab === "health")    return <HealthTab    setSubView={setSubView}/>;
    if (tab === "myinfo")    return <MyHealthInfoTab user={user}/>;
    if (tab === "emergency") return <EmergencyTab setSubView={setSubView}/>;
    if (tab === "profile")   return <ProfileTab   user={user} onLogout={onLogout}/>;
  };

  return (
    <div style={{ maxWidth: 430, margin: "0 auto", background: "#f4f7f5", minHeight: "100vh", position: "relative" }}>

      {/* TOP NAVBAR */}
      <div style={{ position: "sticky", top: 0, zIndex: 100, background: "rgba(244,247,245,.95)", backdropFilter: "blur(12px)",
        borderBottom: "1px solid #e0ece4", padding: "14px 20px", display: "flex", alignItems: "center", justifyContent: "space-between" }}>
        <div style={{ display: "flex", alignItems: "center", gap: 8 }}>
          <div style={{ width: 32, height: 32, borderRadius: 10, background: "linear-gradient(135deg,#2d9e6b,#1565c0)", display: "grid", placeItems: "center" }}>
            <span style={{ color: "#fff", fontSize: 16 }}>⚕</span>
          </div>
          <span style={{ fontFamily: "Fraunces, serif", fontWeight: 700, fontSize: 18, color: "#1a2e24" }}>SwasthayaLink</span>
        </div>
        <div style={{ display: "flex", gap: 10, alignItems: "center" }}>
          <button onClick={() => { setSubView("symptom"); }} style={{ background: "#e4f5ec", border: "none", borderRadius: 10, padding: "7px 12px", cursor: "pointer", display: "flex", alignItems: "center", gap: 5 }}>
            <Icon name="search" size={16} color="#2d9e6b"/>
          </button>
          <button onClick={() => { setSubView("chatbot"); }} style={{ background: "#e4f5ec", border: "none", borderRadius: 10, padding: "7px 12px", cursor: "pointer" }}>
            <Icon name="message" size={16} color="#2d9e6b"/>
          </button>
          <button style={{ background: "none", border: "none", cursor: "pointer", position: "relative" }}>
            <Icon name="bell" size={20} color="#4a7060"/>
            <span style={{ position: "absolute", top: 0, right: 0, width: 7, height: 7, background: "#e53935", borderRadius: "50%" }}/>
          </button>
        </div>
      </div>

      {/* MAIN CONTENT */}
      <div key={subView || tab} className="fade-up" style={{ overflowY: "auto", minHeight: "calc(100vh - 130px)" }}>
        {subView ? renderSubView() : renderTab()}
      </div>

      {/* BOTTOM NAV */}
      <div style={{ position: "fixed", bottom: 0, left: "50%", transform: "translateX(-50%)", width: "100%", maxWidth: 430,
        background: "rgba(255,255,255,.97)", backdropFilter: "blur(16px)", borderTop: "1px solid #e0ece4",
        display: "flex", justifyContent: "space-around", padding: "8px 0 12px", zIndex: 100 }}>
        {navItems.map(n => (
          <button key={n.id} className={`nav-item ${tab === n.id && !subView ? "active" : ""}`}
            onClick={() => { setTab(n.id); setSubView(null); }}>
            <Icon name={n.icon} size={22} color={tab === n.id && !subView ? "#2d9e6b" : "#7a9e8a"}
              strokeWidth={tab === n.id && !subView ? 2.2 : 1.6}/>
            {n.label}
          </button>
        ))}
      </div>

      {/* SOS FAB */}
      <button className="sos-btn" onClick={handleSOS}
        style={{ animation: sosFlash ? "none" : "pulse 2.5s infinite", background: sosFlash ? "#b71c1c" : "linear-gradient(135deg,#e53935,#b71c1c)" }}>
        <Icon name="phone" size={20} color="#fff"/>
        <span>SOS</span>
      </button>
    </div>
  );
}

