// STEP COUNTER
// ════════════════════════════════════════════════════════════════════
const StepCounter = ({ onBack }) => {
  const GOAL = 6000;
  const [steps,      setSteps]      = useState(4821);
  const [isTracking, setIsTracking] = useState(false);
  const [goalInput,  setGoalInput]  = useState(String(GOAL));
  const [goal,       setGoal]       = useState(GOAL);
  const [editGoal,   setEditGoal]   = useState(false);
  const history = [
    { day: "Mon", steps: 3200 }, { day: "Tue", steps: 5800 },
    { day: "Wed", steps: 6100 }, { day: "Thu", steps: 4500 },
    { day: "Fri", steps: 6000 }, { day: "Sat", steps: 5200 },
    { day: "Sun", steps: 4821 },
  ];
  const timerRef = useRef(null);

  useEffect(() => {
    if (!isTracking) { clearInterval(timerRef.current); return; }
    timerRef.current = setInterval(() => {
      setSteps(s => Math.min(s + Math.floor(Math.random() * 3 + 1), 99999));
    }, 550);
    return () => clearInterval(timerRef.current);
  }, [isTracking]);

  const pct      = Math.min((steps / goal) * 100, 100);
  const calories = Math.round(steps * 0.065);
  const km       = (steps * 0.00076).toFixed(2);
  const activeMin= Math.round(steps / 100);
  const goalMet  = steps >= goal;
  const r = 90, stroke = 12, circ = 2 * Math.PI * r;
  const dashOffset = circ - (pct / 100) * circ;

  const milestones = [
    { at: 2000, label: "Warm-up",      icon: "🌱" },
    { at: 4000, label: "Halfway",      icon: "⚡" },
    { at: 6000, label: "Goal!",        icon: "🏆" },
    { at: 8000, label: "Overachiever", icon: "🔥" },
    { at:10000, label: "Champion",     icon: "👑" },
  ];
  const nextMilestone = milestones.find(m => m.at > steps);
  const lastMilestone = [...milestones].reverse().find(m => m.at <= steps);
  const ringColor = goalMet ? "#2d9e6b" : pct > 60 ? "#2d9e6b" : pct > 30 ? "#f57c00" : "#e53935";

  const add   = (n) => setSteps(s => Math.min(s + n, 99999));
  const reset = () => { setIsTracking(false); setSteps(0); };
  const saveGoal = () => { const v = parseInt(goalInput); if (v > 0) setGoal(v); setEditGoal(false); };

  return (
    <div style={{ padding: "0 16px 100px" }}>
      <button onClick={onBack} style={{ background: "none", border: "none", cursor: "pointer", display: "flex", alignItems: "center", gap: 6, color: "#2d9e6b", fontWeight: 600, paddingTop: 20, marginBottom: 4, fontSize: 14 }}>← Back</button>
      <h2 style={{ fontFamily: "Fraunces, serif", fontSize: 24, fontWeight: 700, marginBottom: 2 }}>Step Counter</h2>
      <p style={{ color: "#7a9e8a", fontSize: 13, marginBottom: 20 }}>
        {isTracking ? "🟢 Tracking — walk with your phone" : "Tap Start to begin tracking your steps"}
      </p>

      {/* BIG RING */}
      <div className="card fade-up" style={{ marginBottom: 14, textAlign: "center", padding: "28px 20px" }}>
        <div style={{ position: "relative", display: "inline-flex", alignItems: "center", justifyContent: "center" }}>
          <svg width={200} height={200} style={{ transform: "rotate(-90deg)" }}>
            <circle cx={100} cy={100} r={r} fill="none" stroke="#f0f5f2" strokeWidth={stroke}/>
            <circle cx={100} cy={100} r={r} fill="none" stroke={ringColor} strokeWidth={stroke}
              strokeDasharray={circ} strokeDashoffset={dashOffset} strokeLinecap="round"
              style={{ transition: "stroke-dashoffset .6s cubic-bezier(.4,0,.2,1), stroke .4s" }}/>
          </svg>
          <div style={{ position: "absolute", textAlign: "center" }}>
            <span style={{ fontSize: 36 }}>{goalMet ? "🏆" : isTracking ? "🚶" : "👟"}</span>
            <p style={{ fontFamily: "Fraunces, serif", fontSize: 34, fontWeight: 700, color: "#1a2e24", lineHeight: 1 }}>
              {steps.toLocaleString()}
            </p>
            <p style={{ fontSize: 12, color: "#7a9e8a", fontWeight: 500 }}>steps</p>
            <p style={{ fontSize: 11, color: goalMet ? "#2d9e6b" : "#7a9e8a", fontWeight: 600, marginTop: 2 }}>
              {goalMet ? "Goal reached! 🎉" : `${(goal - steps).toLocaleString()} to go`}
            </p>
          </div>
        </div>

        <div style={{ display: "flex", alignItems: "center", justifyContent: "center", gap: 8, marginTop: 8 }}>
          {editGoal ? (
            <>
              <input value={goalInput} onChange={e => setGoalInput(e.target.value)} type="number"
                style={{ width: 90, padding: "5px 10px", borderRadius: 10, border: "1.5px solid #2d9e6b", fontSize: 13, fontWeight: 600, textAlign: "center", outline: "none" }}/>
              <button onClick={saveGoal} style={{ background: "#2d9e6b", color: "#fff", border: "none", borderRadius: 10, padding: "6px 12px", fontSize: 12, fontWeight: 700, cursor: "pointer" }}>Save</button>
            </>
          ) : (
            <>
              <span style={{ fontSize: 12, color: "#7a9e8a" }}>Daily goal: <strong style={{ color: "#1a2e24" }}>{goal.toLocaleString()} steps</strong></span>
              <button onClick={() => setEditGoal(true)} style={{ background: "#e4f5ec", border: "none", borderRadius: 8, padding: "4px 10px", fontSize: 11, color: "#2d9e6b", fontWeight: 700, cursor: "pointer" }}>Edit</button>
            </>
          )}
        </div>

        <div style={{ background: "#f0f5f2", borderRadius: 8, height: 6, margin: "14px 0 6px" }}>
          <div style={{ width: `${pct}%`, height: 6, background: `linear-gradient(90deg,${ringColor},#64d6a0)`, borderRadius: 8, transition: "width .6s ease" }}/>
        </div>
        <p style={{ fontSize: 11, color: "#7a9e8a" }}>{pct.toFixed(0)}% of daily goal</p>
      </div>

      {/* STATS */}
      <div className="fade-up" style={{ display: "grid", gridTemplateColumns: "repeat(3,1fr)", gap: 10, marginBottom: 14, animationDelay: ".05s" }}>
        {[
          { icon: "🔥", val: calories, unit: "kcal", label: "Calories" },
          { icon: "📍", val: km,       unit: "km",   label: "Distance" },
          { icon: "⏱️", val: activeMin,unit: "min",  label: "Active" },
        ].map((s, i) => (
          <div key={i} className="card" style={{ textAlign: "center", padding: "14px 8px" }}>
            <span style={{ fontSize: 22 }}>{s.icon}</span>
            <p style={{ fontFamily: "Fraunces, serif", fontSize: 20, fontWeight: 700, color: "#1a2e24", marginTop: 4 }}>{s.val}</p>
            <p style={{ fontSize: 9, color: "#7a9e8a" }}>{s.unit}</p>
            <p style={{ fontSize: 9, color: "#7a9e8a", fontWeight: 600 }}>{s.label}</p>
          </div>
        ))}
      </div>

      {/* CONTROLS */}
      <div className="card fade-up" style={{ marginBottom: 14, animationDelay: ".08s" }}>
        <p style={{ fontSize: 12, color: "#7a9e8a", fontWeight: 500, marginBottom: 14 }}>CONTROLS</p>
        <div style={{ display: "flex", gap: 10, marginBottom: 12 }}>
          <button onClick={() => setIsTracking(t => !t)}
            style={{ flex: 2, padding: "14px", borderRadius: 14, border: "none", fontWeight: 700, fontSize: 15, cursor: "pointer",
              background: isTracking ? "linear-gradient(135deg,#e53935,#b71c1c)" : "linear-gradient(135deg,#2d9e6b,#1a7a50)",
              color: "#fff", boxShadow: isTracking ? "0 4px 14px rgba(229,57,53,.35)" : "0 4px 14px rgba(45,158,107,.35)",
              display: "flex", alignItems: "center", justifyContent: "center", gap: 8, transition: "all .25s" }}>
            {isTracking
              ? <><span style={{ fontSize: 18 }}>⏸</span> Pause</>
              : <><span style={{ fontSize: 18 }}>▶</span> {steps > 0 ? "Resume" : "Start"}</>}
          </button>
          <button onClick={reset}
            style={{ flex: 1, padding: "14px", borderRadius: 14, border: "1.5px solid #e0ece4", background: "#fff", fontWeight: 600, fontSize: 14, cursor: "pointer", color: "#c62828", display: "flex", alignItems: "center", justifyContent: "center", gap: 6 }}>
            <span style={{ fontSize: 16 }}>↺</span> Reset
          </button>
        </div>
        <p style={{ fontSize: 11, color: "#7a9e8a", marginBottom: 8, fontWeight: 500 }}>ADD STEPS MANUALLY</p>
        <div style={{ display: "flex", gap: 8 }}>
          {[100, 250, 500, 1000].map(n => (
            <button key={n} onClick={() => add(n)}
              style={{ flex: 1, padding: "9px 4px", borderRadius: 11, border: "1.5px solid #c8e6c9", background: "#f0faf4", fontWeight: 700, fontSize: 12, color: "#1e7a4e", cursor: "pointer", transition: "all .15s" }}>
              +{n}
            </button>
          ))}
        </div>
      </div>

      {/* MILESTONES */}
      {(lastMilestone || nextMilestone) && (
        <div className="card fade-up" style={{ marginBottom: 14, animationDelay: ".1s", background: goalMet ? "linear-gradient(135deg,#e4f5ec,#e3f0fb)" : "#fff" }}>
          <p style={{ fontSize: 12, color: "#7a9e8a", fontWeight: 500, marginBottom: 12 }}>MILESTONES</p>
          <div style={{ display: "flex", gap: 0, overflowX: "auto", paddingBottom: 4 }}>
            {milestones.map((m, i) => {
              const reached = steps >= m.at;
              const isCurrent = lastMilestone?.at === m.at;
              return (
                <div key={i} style={{ flex: "0 0 auto", textAlign: "center", padding: "0 10px", borderRight: i < milestones.length - 1 ? "1px solid #f0f5f2" : "none" }}>
                  <div style={{ width: 44, height: 44, borderRadius: "50%", margin: "0 auto 6px", background: reached ? (isCurrent ? "#2d9e6b" : "#e4f5ec") : "#f4f7f5", display: "flex", alignItems: "center", justifyContent: "center", fontSize: 20, border: isCurrent ? "2px solid #2d9e6b" : "2px solid transparent", transition: "all .4s" }}>{m.icon}</div>
                  <p style={{ fontSize: 10, fontWeight: 700, color: reached ? "#1e7a4e" : "#b0c4b8" }}>{m.at.toLocaleString()}</p>
                  <p style={{ fontSize: 9, color: reached ? "#2d9e6b" : "#c5d9cc" }}>{m.label}</p>
                </div>
              );
            })}
          </div>
          {nextMilestone && !goalMet && (
            <div style={{ marginTop: 12, background: "#f0faf4", borderRadius: 10, padding: "8px 12px", display: "flex", alignItems: "center", gap: 8 }}>
              <span style={{ fontSize: 16 }}>{nextMilestone.icon}</span>
              <p style={{ fontSize: 12, color: "#1e7a4e", fontWeight: 600 }}>{(nextMilestone.at - steps).toLocaleString()} more steps to reach <strong>{nextMilestone.label}</strong>!</p>
            </div>
          )}
          {goalMet && (
            <div style={{ marginTop: 12, background: "linear-gradient(135deg,#2d9e6b,#1a7a50)", borderRadius: 12, padding: "12px 16px", display: "flex", alignItems: "center", gap: 10 }}>
              <span style={{ fontSize: 24 }}>🎉</span>
              <div>
                <p style={{ fontSize: 14, fontWeight: 700, color: "#fff" }}>Daily goal crushed!</p>
                <p style={{ fontSize: 11, color: "rgba(255,255,255,.8)" }}>You've walked {steps.toLocaleString()} steps today</p>
              </div>
            </div>
          )}
        </div>
      )}

      {/* WEEKLY HISTORY */}
      <div className="card fade-up" style={{ marginBottom: 14, animationDelay: ".12s" }}>
        <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: 14 }}>
          <p style={{ fontSize: 12, color: "#7a9e8a", fontWeight: 500 }}>WEEKLY HISTORY</p>
          <span style={{ fontSize: 11, color: "#2d9e6b", fontWeight: 600 }}>Avg: {Math.round(history.reduce((s,d)=>s+d.steps,0)/history.length).toLocaleString()} steps/day</span>
        </div>
        <div style={{ display: "flex", alignItems: "flex-end", gap: 6, height: 80 }}>
          {history.map((d, i) => {
            const isToday = i === history.length - 1;
            const h = Math.max((d.steps / 10000) * 100, 8);
            const met = d.steps >= goal;
            return (
              <div key={i} style={{ flex: 1, display: "flex", flexDirection: "column", alignItems: "center", gap: 4 }}>
                <p style={{ fontSize: 9, color: isToday ? "#2d9e6b" : "#7a9e8a", fontWeight: isToday ? 700 : 400 }}>
                  {d.steps >= 1000 ? (d.steps/1000).toFixed(1)+"k" : d.steps}
                </p>
                <div style={{ width: "100%", height: `${h}%`, borderRadius: "5px 5px 0 0",
                  background: met ? "linear-gradient(180deg,#2d9e6b,#1a7a50)" : isToday ? "linear-gradient(180deg,#64b5f6,#1565c0)" : "#d4e8da",
                  border: isToday ? "2px solid #1565c0" : "none", transition: "height .8s ease", position: "relative" }}>
                  {met && <span style={{ position: "absolute", top: -14, left: "50%", transform: "translateX(-50%)", fontSize: 10 }}>✓</span>}
                </div>
                <p style={{ fontSize: 9, color: isToday ? "#1565c0" : "#7a9e8a", fontWeight: isToday ? 700 : 400 }}>{d.day}</p>
              </div>
            );
          })}
        </div>
        <div style={{ display: "flex", gap: 16, marginTop: 12, justifyContent: "center" }}>
          {[["#2d9e6b","Goal met"],["#64b5f6","Today"],["#d4e8da","Other"]].map(([c,l]) => (
            <div key={l} style={{ display: "flex", alignItems: "center", gap: 4 }}>
              <div style={{ width: 10, height: 10, borderRadius: 3, background: c }}/>
              <span style={{ fontSize: 10, color: "#7a9e8a" }}>{l}</span>
            </div>
          ))}
        </div>
      </div>

      {/* TIPS */}
      <div className="card fade-up" style={{ animationDelay: ".15s", background: "linear-gradient(135deg,#e3f0fb,#e4f5ec)" }}>
        <p style={{ fontSize: 12, color: "#1565c0", fontWeight: 700, marginBottom: 10 }}>💡 WALKING TIPS</p>
        {["Take the stairs instead of the elevator — adds ~200 steps per floor.","Park farther away from your destination to walk more.","A 10-minute walk after each meal helps digestion and adds ~1,200 steps.","Set hourly reminders to stand and walk for 2 minutes."].map((tip, i) => (
          <div key={i} style={{ display: "flex", gap: 8, padding: "6px 0", borderBottom: i < 3 ? "1px solid rgba(0,0,0,.05)" : "none" }}>
            <span style={{ color: "#2d9e6b", fontWeight: 700, fontSize: 13, flexShrink: 0 }}>{i+1}.</span>
            <p style={{ fontSize: 12, color: "#1a2e24", lineHeight: 1.6 }}>{tip}</p>
          </div>
        ))}
      </div>
    </div>
  );
};

