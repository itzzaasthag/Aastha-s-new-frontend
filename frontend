      </div>

      {/* Form */}
      <div className="slide-up" style={{ padding: "0 20px 40px", marginTop: -24 }}>
        <div className="card" style={{ padding: 24 }}>
          <div style={{ fontFamily: "Fraunces, serif", fontSize: 22, fontWeight: 700, marginBottom: 4 }}>Welcome back 👋</div>
          <div style={{ fontSize: 13, color: "#7a9e8a", marginBottom: 20 }}>Sign in to continue</div>

          {err && (
            <div style={{ background: "#fde8e8", borderRadius: 12, padding: "10px 14px", fontSize: 13, color: "#c62828", fontWeight: 600, marginBottom: 14 }}>
              ⚠️ {err}
            </div>
          )}

          {/* Email */}
          <div style={{ marginBottom: 12 }}>
            <div style={{ fontSize: 11, fontWeight: 700, color: "#7a9e8a", letterSpacing: ".06em", marginBottom: 6 }}>EMAIL ADDRESS</div>
