// ROOT — manages auth screen state
// ════════════════════════════════════════════════════════════════════
export default function SwasthayaLink() {
  // "splash" | "login" | "register" | "dashboard"
  const [screen, setScreen] = useState("splash");
  const [user,   setUser]   = useState(null);

  // Both Login and Register call this — goes straight to dashboard
  function enterApp(u) {
    setUser(u);
    setScreen("dashboard");
  }

  function logout() {
    setUser(null);
    setScreen("login");
  }

  return (
    <>
      <style dangerouslySetInnerHTML={{ __html: GLOBAL_CSS }}/>
      <div style={{ maxWidth: 430, margin: "0 auto", minHeight: "100vh", fontFamily: "'DM Sans', sans-serif" }}>
        {screen === "splash"    && <Splash    next={() => setScreen("login")}/>}
        {screen === "login"     && <Login     goHome={enterApp} goRegister={() => setScreen("register")}/>}
        {screen === "register"  && <Register  goHome={enterApp} goLogin={() => setScreen("login")}/>}
        {screen === "dashboard" && user       && <Dashboard user={user} onLogout={logout}/>}
      </div>
    </>
  );
}
