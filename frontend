          </div>

          <div style={{ flex:1 }}>
            <p style={{ fontFamily:"Fraunces, serif", fontSize:30, fontWeight:700, color:"#1a2e24", lineHeight:1 }}>
              {water.toLocaleString()}<span style={{ fontSize:13, fontWeight:300, color:"#7a9e8a" }}>ml</span>
            </p>

            {/* Goal row with inline edit */}
            <div style={{ display:"flex", alignItems:"center", gap:6, margin:"8px 0 4px" }}>
              {editGoal ? (
                <>
                  <span style={{ fontSize:11, color:"#7a9e8a" }}>Goal:</span>
                  <input type="number" value={goalInput} onChange={e => setGoalInput(e.target.value)}
                    style={{ width:72, padding:"4px 8px", borderRadius:8, border:"1.5px solid #2d9e6b", fontSize:12, fontWeight:600, outline:"none", textAlign:"center", background:"#fafffe", color:"#1a2e24" }}/>
                  <span style={{ fontSize:11, color:"#7a9e8a" }}>ml</span>
                  <button onClick={() => { const v=parseInt(goalInput); if(v>0){setWaterGoal(v); setGoalInput(String(v));} setEditGoal(false); }}
                    style={{ background:"#2d9e6b", color:"#fff", border:"none", borderRadius:7, padding:"4px 10px", fontSize:11, fontWeight:700, cursor:"pointer" }}>✓ Save</button>
                  <button onClick={() => setEditGoal(false)}
                    style={{ background:"#f0f5f2", color:"#7a9e8a", border:"none", borderRadius:7, padding:"4px 8px", fontSize:11, cursor:"pointer" }}>✕</button>
                </>
              ) : (
                <>
                  <span style={{ fontSize:12, color:"#7a9e8a" }}>Goal: <strong style={{ color:"#1a2e24" }}>{waterGoal.toLocaleString()}ml</strong></span>
                  <button onClick={() => { setGoalInput(String(waterGoal)); setEditGoal(true); }}
                    style={{ background:"#e4f5ec", border:"none", borderRadius:7, padding:"3px 9px", fontSize:10, color:"#2d9e6b", fontWeight:700, cursor:"pointer" }}>✏️ Edit</button>
                </>
              )}
            </div>

            <div style={{ background:"#e8f4fd", borderRadius:8, height:7, marginBottom:6, overflow:"hidden" }}>
              <div style={{ width:`${waterPct}%`, height:"100%", background: waterPct>=100?"#2d9e6b":"linear-gradient(90deg,#64b5f6,#1565c0)", borderRadius:8, transition:"width .6s ease" }}/>
            </div>
            <p style={{ fontSize:11, color: waterPct>=100?"#1e7a4e":"#7a9e8a", fontWeight: waterPct>=100?700:400 }}>
              {waterPct >= 100 ? "Goal reached! Great job today!" : `${(waterGoal - water).toLocaleString()}ml remaining`}
            </p>
          </div>
        </div>

        {/* ── Quick Add Buttons ── */}
        <div style={{ display:"flex", gap:7, marginBottom:14 }}>
          {[150, 250, 350, 500].map(amt => (
            <button key={amt} onClick={() => {
              setWater(w => w + amt);
              const t = new Date(); const ts = t.getHours().toString().padStart(2,"0")+":"+t.getMinutes().toString().padStart(2,"0");
              setDrinkLog(l => [{ time:ts, label:`${amt}ml drink`, amount:amt }, ...l].slice(0,20));
            }} style={{ flex:1, padding:"9px 4px", borderRadius:11, border:"1.5px solid #90caf9", background:"#e3f0fb", fontWeight:700, fontSize:12, color:"#1565c0", cursor:"pointer" }}>
              +{amt}
            </button>
          ))}
        </div>

        {/* ── Custom Amount ── */}
        <div style={{ borderTop:"1px solid #f0f5f2", paddingTop:12, marginBottom:14 }}>
          <p style={{ fontSize:11, color:"#7a9e8a", fontWeight:600, marginBottom:8 }}>CUSTOM AMOUNT</p>
          <div style={{ display:"flex", gap:8 }}>
            <input type="number" value={customAmt} onChange={e => setCustomAmt(e.target.value)}
              onKeyDown={e => { if(e.key==="Enter"){ const v=parseInt(customAmt); if(v>0){ setWater(w=>w+v); const t=new Date(); const ts=t.getHours().toString().padStart(2,"0")+":"+t.getMinutes().toString().padStart(2,"0"); setDrinkLog(l=>[{time:ts,label:"Custom entry",amount:v},...l].slice(0,20)); setCustomAmt(""); }}}}
              placeholder="Enter ml e.g. 330"
              style={{ flex:1, padding:"10px 14px", borderRadius:12, border:"1.5px solid #d4e8da", background:"#fafffe", fontSize:13, outline:"none", color:"#1a2e24" }}/>
            <button className="btn-primary" onClick={() => { const v=parseInt(customAmt); if(v>0){ setWater(w=>w+v); const t=new Date(); const ts=t.getHours().toString().padStart(2,"0")+":"+t.getMinutes().toString().padStart(2,"0"); setDrinkLog(l=>[{time:ts,label:"Custom entry",amount:v},...l].slice(0,20)); setCustomAmt(""); }}}
              style={{ padding:"10px 18px", fontSize:13, whiteSpace:"nowrap" }}>
