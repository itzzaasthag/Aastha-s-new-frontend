              <div style={{ background: "#e4f5ec", borderRadius: 12, padding: "10px 14px", fontSize: 12, color: "#1e7a4e", fontWeight: 500 }}>
                🛡️ Your insurance details are stored securely and used only in emergencies.
              </div>
            </div>
          )}
        </div>

      </div>{/* end accordion */}

      {/* Save button */}
      <div style={{ marginTop: 24 }}>
        <button className="btn-primary" onClick={handleSave}
          style={{ width: "100%", fontSize: 15, padding: 15, display: "flex", alignItems: "center", justifyContent: "center", gap: 8 }}>
          {saved ? <><Icon name="check" size={18} color="#fff"/> Saved Successfully!</> : "💾  Save Health Profile"}
        </button>
        {saved && (
          <div style={{ background: "#e4f5ec", borderRadius: 14, padding: "12px 16px", marginTop: 12, textAlign: "center" }}>
            <p style={{ color: "#1e7a4e", fontWeight: 600, fontSize: 13 }}>✅ Your health profile has been saved. Doctors can now access this in emergencies.</p>
          </div>
        )}
      </div>
    </div>
  );
};

