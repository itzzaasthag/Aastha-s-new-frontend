          <button onClick={() => { setWater(0); setDrinkLog([]); }}
            style={{ background:"#fde8e8", border:"none", borderRadius:8, padding:"4px 10px", fontSize:11, color:"#c62828", fontWeight:700, cursor:"pointer" }}>
            Reset day
          </button>
        </div>

        {/* ── Bottle + Main Stats ── */}
        <div style={{ display:"flex", gap:18, alignItems:"center", marginBottom:16 }}>
          <div style={{ flexShrink:0, textAlign:"center" }}>
            <div className="water-container" style={{ width:72, height:126, margin:"0 auto" }}>
              <div className="water-fill" style={{ height:`${waterPct}%` }}>
                <div className="water-wave"/>
              </div>
              <div style={{ position:"absolute", inset:0, display:"flex", alignItems:"center", justifyContent:"center" }}>
                <span style={{ fontSize:12, fontWeight:800, color: waterPct > 48 ? "#fff" : "#1565c0", zIndex:2, position:"relative" }}>
                  {Math.round(waterPct)}%
                </span>
              </div>
            </div>
            <p style={{ fontSize:10, color:"#7a9e8a", marginTop:5, fontWeight:600 }}>
              {waterPct >= 100 ? "Done!" : waterPct >= 70 ? "Almost!" : waterPct >= 40 ? "Halfway" : "Keep going"}
