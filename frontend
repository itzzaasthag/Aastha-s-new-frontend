          { label: "First Aid Guide",    icon: "🩹", action: () => setSubView("firstaid") },
          { label: "Share Live Location",icon: "📍", action: () => {} },
          { label: "Emergency Contacts", icon: "👥", action: () => {} },
        ].map((a, i) => (
          <div key={i} className="card" style={{ cursor: "pointer", padding: 16 }} onClick={a.action}>
            <span style={{ fontSize: 28 }}>{a.icon}</span>
            <p style={{ fontSize: 13, fontWeight: 700, marginTop: 8 }}>{a.label}</p>
          </div>
        ))}
      </div>
    </div>
  );
};

