              <span style={{ fontSize:11, color:"#2d9e6b", fontWeight:600 }}>
                {drinkLog.length} entries · {drinkLog.reduce((s,e)=>s+e.amount,0).toLocaleString()}ml
              </span>
            </div>
            <div style={{ maxHeight:180, overflowY:"auto" }}>
              {drinkLog.map((entry, i) => (
                <div key={i} style={{ display:"flex", alignItems:"center", justifyContent:"space-between", padding:"7px 0", borderBottom: i<drinkLog.length-1?"1px solid #f4f7f5":"none" }}>
                  <div style={{ display:"flex", alignItems:"center", gap:10 }}>
                    <div style={{ width:32, height:32, borderRadius:10, background:"#e3f0fb", display:"flex", alignItems:"center", justifyContent:"center", fontSize:15 }}>💧</div>
                    <div>
                      <p style={{ fontSize:12, fontWeight:600, color:"#1a2e24" }}>{entry.label}</p>
                      <p style={{ fontSize:10, color:"#7a9e8a" }}>{entry.time}</p>
                    </div>
                  </div>
                  <div style={{ display:"flex", alignItems:"center", gap:8 }}>
                    <span style={{ fontFamily:"Fraunces, serif", fontSize:14, fontWeight:700, color:"#1565c0" }}>+{entry.amount}ml</span>
                    <button onClick={() => { setWater(w=>Math.max(0,w-entry.amount)); setDrinkLog(l=>l.filter((_,idx)=>idx!==i)); }}
                      style={{ background:"#fde8e8", border:"none", borderRadius:6, width:22, height:22, fontSize:10, color:"#c62828", cursor:"pointer", fontWeight:700, display:"flex", alignItems:"center", justifyContent:"center" }}>✕</button>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}

        {/* ── Tips ── */}
        <div style={{ marginTop:14, background:"linear-gradient(135deg,#e3f0fb,#e8f5e9)", borderRadius:14, padding:"12px 14px" }}>
          <p style={{ fontSize:11, color:"#1565c0", fontWeight:700, marginBottom:6 }}>💡 Hydration Tips</p>
          <p style={{ fontSize:11, color:"#1a2e24", lineHeight:1.75 }}>
            Start your morning with a full glass of water. Add 500ml on workout days.
            Thirst is often mistaken for hunger — try water first!
          </p>
        </div>

      </div>
      {/* VITALS */}
      <div className="card fade-up" style={{ marginBottom: 14, animationDelay: ".2s" }}>
        <p style={{ fontSize: 12, color: "#7a9e8a", fontWeight: 500, marginBottom: 14 }}>VITALS MONITORING</p>
        <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr 1fr", gap: 10 }}>
          {[
            { label: "Heart Rate",     val: "72",     unit: "bpm",   icon: "❤️", color: "#fde8e8", tcolor: "#c62828" },
            { label: "Blood Pressure", val: "120/80", unit: "mmHg",  icon: "🩺", color: "#e3f0fb", tcolor: "#1565c0" },
            { label: "Blood Glucose",  val: "98",     unit: "mg/dL", icon: "🩸", color: "#fff3e0", tcolor: "#e65100" },
          ].map((v, i) => (
            <div key={i} style={{ background: v.color, borderRadius: 16, padding: 12, textAlign: "center" }}>
              <span style={{ fontSize: 20 }}>{v.icon}</span>
              <p style={{ fontFamily: "Fraunces, serif", fontSize: 16, fontWeight: 700, color: v.tcolor, marginTop: 4 }}>{v.val}</p>
              <p style={{ fontSize: 9, color: "#4a7060" }}>{v.unit}</p>
              <p style={{ fontSize: 9, color: "#7a9e8a" }}>{v.label}</p>
            </div>
          ))}
        </div>
        <button className="btn-primary" style={{ width: "100%", marginTop: 12, fontSize: 13 }}>+ Add Reading</button>
      </div>

      {/* MINDFULNESS */}
      <div className="card fade-up" style={{ marginBottom: 14, animationDelay: ".25s" }}>
        <p style={{ fontSize: 12, color: "#7a9e8a", fontWeight: 500, marginBottom: 12 }}>MINDFULNESS</p>
        <p style={{ fontSize: 13, fontWeight: 600, marginBottom: 10 }}>How are you feeling today?</p>
        <div style={{ display: "flex", gap: 10, marginBottom: 16 }}>
          {["😔","😐","🙂","😊","🤩"].map((e, i) => (
            <button key={i} className={`mood-btn ${mood === i ? "selected" : ""}`} onClick={() => setMood(i)}>{e}</button>
          ))}
        </div>
        <div style={{ background: "linear-gradient(135deg,#e3f0fb,#e4f5ec)", borderRadius: 16, padding: 16, textAlign: "center" }}>
          <div style={{ width: 50, height: 50, borderRadius: "50%", background: breatheOn ? "#2d9e6b" : "#90caf9",
            margin: "0 auto 10px", transition: "all 4s ease",
            animation: breatheOn ? "breathe 8s infinite ease-in-out" : "none" }}/>
          <p style={{ fontSize: 13, fontWeight: 600, marginBottom: 8 }}>{breatheOn ? "Breathe in… breathe out…" : "4-7-8 Breathing"}</p>
          <button className="btn-primary" style={{ fontSize: 12 }} onClick={() => setBreatheOn(b => !b)}>
            {breatheOn ? "Stop" : "Start Exercise"}
          </button>
        </div>
      </div>

      {/* WORKOUT */}
      <div className="card fade-up" style={{ marginBottom: 14, animationDelay: ".3s" }}>
        <p style={{ fontSize: 12, color: "#7a9e8a", fontWeight: 500, marginBottom: 12 }}>WORKOUT</p>
        <div style={{ display: "flex", gap: 10 }}>
          {[
            { label: "Walking", dur: "32 min", cal: 180, icon: "🚶" },
            { label: "Running", dur: "—",      cal: "—",  icon: "🏃" },
            { label: "Yoga",    dur: "20 min", cal: 90,   icon: "🧘" },
          ].map((w, i) => (
            <div key={i} style={{ flex: 1, background: i === 0 ? "#e4f5ec" : "#f4f7f5", borderRadius: 14, padding: 12, textAlign: "center" }}>
              <span style={{ fontSize: 22 }}>{w.icon}</span>
              <p style={{ fontSize: 11, fontWeight: 700, marginTop: 4 }}>{w.label}</p>
              <p style={{ fontSize: 10, color: "#7a9e8a" }}>{w.dur}</p>
              <p style={{ fontSize: 10, color: "#2d9e6b", fontWeight: 600 }}>{w.cal !== "—" ? `${w.cal}kcal` : "Start"}</p>
            </div>
          ))}
        </div>
        <button className="btn-primary" style={{ width: "100%", marginTop: 12, fontSize: 13 }}>+ Log Workout</button>
      </div>

      {/* HEALTH RECORDS */}
      <div className="card fade-up" style={{ marginBottom: 14, animationDelay: ".35s" }}>
        <p style={{ fontSize: 12, color: "#7a9e8a", fontWeight: 500, marginBottom: 12 }}>HEALTH RECORDS</p>
        <div style={{ display: "flex", gap: 10 }}>
          {["📄 Blood Report\nMar 10, 2026", "🩻 X-Ray\nFeb 22, 2026"].map((r, i) => (
            <div key={i} style={{ flex: 1, background: "#f4f7f5", borderRadius: 14, padding: 12 }}>
              <p style={{ fontSize: 12, fontWeight: 600, whiteSpace: "pre-line", lineHeight: 1.6 }}>{r}</p>
            </div>
          ))}
        </div>
        <button className="btn-primary" style={{ width: "100%", marginTop: 12, fontSize: 13 }}>
          <Icon name="upload" size={14} color="#fff"/> Upload Record
        </button>
      </div>

      {/* Supplements CTA */}
      <div style={{ background: "linear-gradient(135deg,#1a7a50,#2d9e6b)", borderRadius: 20, padding: 20, color: "#fff", marginBottom: 14 }}>
        <p style={{ fontSize: 14, fontWeight: 700 }}>Recommended Supplements</p>
        <p style={{ fontSize: 12, opacity: .8, marginBottom: 12 }}>Based on your health profile</p>
        <button style={{ background: "#fff", color: "#1a7a50", border: "none", borderRadius: 12, padding: "10px 18px", fontWeight: 700, fontSize: 13, cursor: "pointer" }}
          onClick={() => setSubView("store")}>Shop Now →</button>
      </div>
    </div>
  );
};

