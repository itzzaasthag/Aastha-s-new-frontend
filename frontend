              background: symptoms.includes(s) ? "#e4f5ec" : "#fff",
              color: symptoms.includes(s) ? "#1e7a4e" : "#4a7060",
              fontWeight: 600, fontSize: 13, cursor: "pointer", transition: "all .2s" }}>
            {s}
